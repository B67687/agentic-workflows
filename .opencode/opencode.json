{
  "$schema": "https://opencode.ai/config.json",
  "instructions": ["workflow/session-state.json"],
  "default_agent": "orchestrator",
  "provider": {
    "opencode-go": {
      "env": ["GITHUB_TOKEN", "GOOGLE_API_KEY", "OPENCODE_GO_API_KEY"],
      "models": {
        "kimi-k2.6": {},
        "minimax-m2.5": {},
        "minimax-m2.7": {},
        "qwen3.5-plus": {},
        "qwen3.6-plus": {},
        "mimo-v2-omni": {},
        "mimo-v2-pro": {},
        "mimo-v2.5": {},
        "mimo-v2.5-pro": {},
        "glm-5": {},
        "glm-5.1": {},
        "deepseek-v4-pro": {},
        "deepseek-v4-flash": {}
      }
    },

    "opencode": {
      "env": ["GITHUB_TOKEN", "GOOGLE_API_KEY", "OPENCODE_GO_API_KEY"],
      "models": {
        "minimax-m2.5-free": {},
        "gpt-5.4-nano": {},
        "gpt-5.5": {},
        "hy3-preview-free": {},
        "trinity-large-preview-free": {}
      }
    }
  },

  "agent": {
    "orchestrator": {
      "mode": "primary",
      "model": "opencode-go/minimax-m2.5",
      "small_model": "opencode-go/minimax-m2.5",
      "description": "Main orchestrator agent.",
      "prompt": "prompts/orchestrator.md",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "webfetch": "allow",
        "skill": "allow",
        "task": {
          "*": "deny",
          "explorer": "allow",
          "worker": "allow"
        }
      }
    },
    "build": { "disable": true }
  },

  "lsp": {
    "python": {
      "command": ["pyright"],
      "extensions": [".custom"]
    },
    "javascript": {
      "command": ["typescript-language-server"],
      "extensions": [".custom"]
    },
    "rust": {
      "command": ["rust-analyzer"],
      "extensions": [".custom"]
    },
    "r": {
      "command": ["R --slave -e languageserver::run()"],
      "extensions": [".custom"]
    }
  },

  "mcp": {
    "filesystem": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-filesystem"],
      "enabled": true
    },
    "sequential-thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true
    },
    "memory": {
      "type": "local",
      "command": ["npx", "-y", "@modelcontextprotocol/server-memory"],
      "enabled": true
    },
    // "fetch": {
    //   "type": "local",
    //   "command": ["npx", "-y", "@modelcontextprotocol/server-fetch"],
    //   "enabled": false
    // },
    // "git": {
    //   "type": "local",
    //   "command": ["npx", "-y", "@modelcontextprotocol/server-git"],
    //   "enabled": false
    // },
    "github": {
      "type": "remote",
      "url": "https://server.smithery.ai/github/mcp",
      "enabled": true
    }
  },

  "formatter": {
    "python": {
      "tool": "black",
      "args": ["--line-length", "88"]
    },
    "python_imports": {
      "tool": "isort",
      "args": ["--profile", "black"]
    },
    "javascript": {
      "tool": "prettier",
      "args": ["--single-quote", "--trailing-comma", "es5"]
    },
    "typescript": {
      "tool": "prettier",
      "args": ["--single-quote", "--trailing-comma", "all"]
    },
    "rust": {
      "tool": "rustfmt",
      "args": ["--edition", "2021"]
    },
    "java": {
      "tool": "google-java-format",
      "args": ["--aosp"]
    },
    "cpp": {
      "tool": "clang-format",
      "args": ["-style=Google"]
    },
    "markdown": {
      "tool": "prettier",
      "args": ["--prose-wrap", "always"]
    }
  }
}
